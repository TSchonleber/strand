# Strand — agent harness architecture (D2 source).
# Render:
#   d2 --layout=elk --theme=200 --dark-theme=200 --pad=48 \
#      docs/diagrams/strand-architecture.d2 \
#      docs/diagrams/strand-architecture.svg

vars: {
  d2-config: {
    layout-engine: elk
    pad: 48
    theme-id: 200
    dark-theme-id: 200
  }
}

title: |md
# Strand — agent harness
provider-agnostic LLM · agentic tool loop · desktop/computer use · typestate policy gate · brainctl memory
| {
  near: top-center
  shape: text
  style.font-size: 22
  style.bold: true
}

# ═════════════════════ External services ═════════════════════

external: External services {
  near: top-center

  x: X API v2 {
    shape: cloud
    tooltip: "OAuth 2.0 PKCE · Basic tier 10k posts/mo · no follow endpoint · refresh tokens rotate every call"
  }

  llm: LLM provider {
    shape: cloud
    style.fill: "#4c1d95"
    style.stroke: "#a78bfa"
    tooltip: "Adapter selected by LLM_PROVIDER env. xAI · OpenAI-compatible · Anthropic · Gemini. Each declares capabilities — loops degrade gracefully on missing features."
  }

  llm-adapters: |md
    **4 adapters · one LlmProvider interface**
    `src/clients/llm/{openai,anthropic,xai,gemini}.ts`

    — **xai** · grok-4.20-reasoning
      x_search · web_search · MCP · Batch · cache · prev_response_id
    — **openai-compat** · gpt-5 / Ollama / Groq / Together
      Chat Completions · Batch · auto cache
    — **anthropic** · claude-opus-4-7
      messages · web_search · MCP · cache_control
    — **gemini** · gemini-2.5-pro
      google_search · code_execution · auto cache
  | {
    shape: text
    style.font-size: 11
  }
  llm -- llm-adapters {
    style.stroke-dash: 2
    style.opacity: 0.6
  }

  brain: brainctl {
    shape: cylinder
    tooltip: "Dual surface: remote MCP (HTTP/SSE) for the LLM provider with READ allowlist · local stdio MCP for TS-direct writes"
  }
  brain-tools: |md
    **READ allowlist (LLM)**
    `memory_search` · `entity_get` · `entity_search`
    `context_search` · `tom_perspective_get`
    `policy_match` · `reason` · `temporal_*`

    **+ consolidator writes**
    `reflexion_write` · `dream_cycle`
    `consolidation_run` · `gaps_scan`
    `retirement_analysis`

    **NEVER exposed**
    `memory_add` · `entity_create` · `event_add`
    `belief_set` · `policy_add` · `trust_*`
  | {
    shape: text
    style.font-size: 11
  }
  brain -- brain-tools {
    style.stroke-dash: 2
    style.opacity: 0.6
  }
}

# ═════════════════════ Strand process ═════════════════════

strand: strand process {
  style.stroke: "#3b82f6"
  style.stroke-width: 2
  tooltip: "src/orchestrator.ts — in-process intervals (dev) · migrate to a queue when prod needs it"

  factory: |md
    ## llm() factory
    `src/clients/llm/index.ts`

    singleton switch on `LLM_PROVIDER`
    validates per-provider API key
    logs capabilities at boot
    tests: `_resetLlmForTests()`
  | {
    shape: rectangle
    style.fill: "#1e293b"
    style.stroke: "#a78bfa"
    style.font-color: "#ede9fe"
  }

  agent_loop: |md
    ## runAgenticLoop
    `src/agent/loop.ts`

    provider-agnostic tool-call iteration
    merges localTools + server tools + MCP
    chat → execute tool locally → re-chat
    cap via maxIterations (default 10)
    dispatches `computer_use` calls
    to `ComputerExecutor` (NoopExecutor default)
    full trace + summed usage returned
  | {
    shape: rectangle
    style.fill: "#1e293b"
    style.stroke: "#38bdf8"
    style.font-color: "#dbeafe"
  }

  executor: |md
    ## ComputerExecutor
    `src/agent/executor.ts`

    **NoopExecutor** (default) — shadow-mode,
    logs intent, never touches the host

    **DockerExecutor** (implemented) — real sandbox
    Xvfb + fluxbox + x11vnc + xdotool + scrot
    via `docker exec`. `markSafe()` gate required
    before gated/live use. 16 KB bash cap,
    64 KB stdout truncation, argv-only injection
    (no shell interpolation).

    screenshot · click · type · key · scroll
    bash · textEditor · cursorPosition · wait
  | {
    shape: rectangle
    style.fill: "#1e293b"
    style.stroke: "#fbbf24"
    style.font-color: "#fef3c7"
  }

  perceiver: |md
    ## Perceiver
    **every 120 s**
    src/loops/perceiver.ts

    • own mentions (sinceId)
    • home timeline
    • DM events
    • NO external scouting
  | {
    shape: rectangle
    style.fill: "#1e3a8a"
    style.stroke: "#3b82f6"
    style.font-color: "#dbeafe"
  }

  reasoner: |md
    ## Reasoner
    **every 300 s · provider-agnostic**
    src/loops/reasoner.ts

    reads last 50 `perceived_events`
    emits up to 10 `CandidateEnvelope[]`

    `llm().chat({ messages, tools, structuredOutput })`
    `promptCacheKey: strand:reasoner:v1`
    `maxTurns: 5` · tools from `capabilities.serverSideTools`
    schema: `anyOf` per action.kind

    stuck-mid-thought → retry with
    `previousResponseId` (when supported)
  | {
    shape: rectangle
    style.fill: "#4c1d95"
    style.stroke: "#a78bfa"
    style.font-color: "#ede9fe"
  }

  gate: |md
    ## Policy Gate
    **8 rules · typestate**

    1 banned_topic
    2 prefilter (regex+topic+embedding)
    3 rate caps (day + hour)
    4 cooldowns (per-target)
    5 relevance ≥ 0.65
    6 dup cos < 0.85 (7d)
    7 diversity (cluster + kind)
    8 dm mutual required
    + human_review

    mints `Candidate<"approved">`
  | {
    shape: hexagon
    style.fill: "#7f1d1d"
    style.stroke: "#ef4444"
    style.stroke-width: 3
    style.font-color: "#fee2e2"
    style.bold: true
  }

  actor: |md
    ## Actor
    **event-driven · shadow/gated/live**
    src/loops/actor.ts

    accepts only `Candidate<"approved">`

    1. SHA-256 idempotency
    2. dispatch per action.kind
       like · bookmark · post · reply · quote · dm
       follow/unfollow (Pro gated)
    3. rate counters++ · cooldowns
    4. `brain.outcome_annotate`
  | {
    shape: rectangle
    style.fill: "#78350f"
    style.stroke: "#f59e0b"
    style.font-color: "#fef3c7"
  }

  consolidator: |md
    ## Consolidator
    **submit 24 h · poll 30 min**
    _poll not yet wired_

    5 task JSONL via llm.filesUpload → batchCreate
    _if `capabilities.batch` — else sync fallback_

    tasks: dream_cycle · consolidation_run
    gaps_scan · retirement_analysis
    reflexion_write
  | {
    shape: rectangle
    style.fill: "#083344"
    style.stroke: "#06b6d4"
    style.font-color: "#cffafe"
  }

  sqlite: |md
    ## SQLite ops store
    src/db/schema.sql

    `action_log` idempotency_key UK
    `cooldowns` · `rate_counters`
    `reasoner_runs` · `consolidator_runs`
    `post_embeddings` (7d dup window)
    `perceived_events` · `dlq`
    `human_review_queue`

    _brain.db owns the semantic layer —_
    _strand.db is audit + ops only_
  | {
    shape: cylinder
    style.fill: "#042f2e"
    style.stroke: "#14b8a6"
    style.font-color: "#ccfbf1"
  }

  # intra edges
  factory -> reasoner: "llm()" { style.stroke: "#a78bfa" }
  factory -> consolidator: "llm() + hasBatch()" { style.stroke: "#a78bfa" }
  factory -> agent_loop: "provider.chat()" { style.stroke: "#a78bfa"; style.stroke-dash: 3 }
  agent_loop -> executor: "dispatch computer_use" { style.stroke: "#fbbf24" }
  reasoner -> agent_loop: "(opt-in for\\nfunction-tool loops)" { style.stroke: "#64748b"; style.stroke-dash: 4 }
  perceiver -> sqlite: "INSERT perceived_events"
  sqlite -> reasoner: "SELECT last 50 events" { style.stroke-dash: 3 }
  reasoner -> gate: "CandidateEnvelope[]" { style.stroke: "#a78bfa"; style.stroke-width: 2 }
  gate -> actor: "Candidate<approved>" { style.stroke: "#10b981"; style.stroke-width: 3; style.bold: true }
  gate -> sqlite: "rejected → action_log + reasons[]" { style.stroke: "#f87171"; style.stroke-dash: 3 }
  actor -> sqlite: "action_log + rate_counters"
  reasoner -> sqlite: "reasoner_runs"
  consolidator -> sqlite: "consolidator_runs"
}

# ═════════════════════ External ↔ Strand ═════════════════════

external.x -> strand.perceiver: "poll" { style.stroke: "#38bdf8"; style.stroke-width: 2 }
strand.actor -> external.x: "writes" { style.stroke: "#38bdf8"; style.stroke-width: 3; style.bold: true }
external.llm -> strand.factory: "provider.chat()" { style.stroke: "#c084fc"; style.stroke-width: 2 }
external.llm -> strand.factory: "provider.batch*()" { style.stroke: "#c084fc"; style.stroke-dash: 4 }
external.brain -> strand.reasoner: "MCP read" { style.stroke: "#10b981"; style.stroke-width: 2 }
external.brain -> strand.consolidator: "MCP read + consolidation" { style.stroke: "#10b981"; style.stroke-dash: 4 }
strand.perceiver -> external.brain: "event_add" { style.stroke: "#10b981"; style.stroke-dash: 2 }
strand.actor -> external.brain: "outcome_annotate" { style.stroke: "#10b981"; style.stroke-dash: 2 }

# ═════════════════════ Phase status ═════════════════════

status: Phase status {
  near: bottom-center
  grid-columns: 3
  grid-gap: 24

  wired: |md
    ### ✓ wired on main
    • typestate gate · reasoner via runAgenticLoop
    • 4 adapters: openai-compat · anthropic · xai · gemini
    • `llm()` factory + capabilities-driven features
    • `runAgenticLoop` — local tool-call iteration runner
    • computer-use tool type + Anthropic native mapping
    • `NoopExecutor` + real `DockerExecutor`
       (Xvfb + xdotool + scrot via `docker exec`)
    • consolidator: xAI/OpenAI file batch · Anthropic inline
       batch · sync fallback (Gemini) — all through hasBatch
       / hasInlineBatch / hasBatchPoll guards
    • consolidatorPoll wired (30 min)
    • multi-turn message history native on xAI
    • 177 tests · smoke 281 ms · typecheck+biome clean
  | {
    shape: rectangle
    style.fill: "#064e3b"
    style.stroke: "#10b981"
    style.font-color: "#d1fae5"
  }

  next: |md
    ### ⟳ next
    • X v2 live writes on real creds (phase 3)
    • OAuth setup + bootstrap-memory runs
    • grokCompose opt-in (two-stage composer)
    • Docker image `strand-sandbox:latest` build
    • label 100 candidates · ≥ 80% shadow agreement
    • phase 7: Pro tier → follow variant live
    • Gemini Batch API (Vertex path)
  | {
    shape: rectangle
    style.fill: "#451a03"
    style.stroke: "#f59e0b"
    style.font-color: "#fde68a"
  }

  never: |md
    ### ✕ never
    • DMs to non-mutuals
    • action bypassing the policy gate
    • brainctl mutations via remote MCP
    • prompts as inline strings
    • provider-specific leakage outside `src/clients/llm/`
    • follow variant on Basic tier
  | {
    shape: rectangle
    style.fill: "#450a0a"
    style.stroke: "#ef4444"
    style.font-color: "#fecaca"
  }
}
