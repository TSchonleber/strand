# Strand вЂ” agent harness architecture (D2 source).
# Render:
#   d2 --layout=elk --theme=200 --dark-theme=200 --pad=48 \
#      docs/diagrams/strand-architecture.d2 \
#      docs/diagrams/strand-architecture.svg

vars: {
  d2-config: {
    layout-engine: elk
    pad: 48
    theme-id: 200
    dark-theme-id: 200
  }
}

title: |md
# Strand вЂ” agent harness
provider-agnostic LLM В· BYOK + OAuth В· agentic tool loop В· desktop/computer use В· typestate policy gate В· brainctl memory
| {
  near: top-center
  shape: text
  style.font-size: 20
  style.bold: true
}

# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ External services в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

external: External services {
  near: top-center

  x: X API v2 {
    shape: cloud
    tooltip: "OAuth 2.0 PKCE В· Basic tier 10k posts/mo В· no follow endpoint В· refresh tokens rotate every call"
  }

  llm: LLM provider {
    shape: cloud
    style.fill: "#4c1d95"
    style.stroke: "#a78bfa"
    tooltip: "Adapter selected by LLM_PROVIDER env. xAI В· OpenAI-compatible В· Anthropic В· Gemini. Each declares capabilities вЂ” loops degrade gracefully on missing features."
  }

  llm-adapters: |md
    **4 adapters В· one LlmProvider interface**
    `src/clients/llm/{openai,anthropic,xai,gemini}.ts`

    вЂ” **xai** В· grok-4.20-reasoning
      x_search В· web_search В· MCP В· Batch В· cache В· prev_response_id
    вЂ” **openai-compat** В· gpt-5 / Ollama / Groq / Together
      Chat Completions В· Batch В· auto cache
    вЂ” **anthropic** В· claude-opus-4-7
      messages В· web_search В· MCP В· cache_control
    вЂ” **gemini** В· gemini-2.5-pro
      google_search В· code_execution В· auto cache
  | {
    shape: text
    style.font-size: 11
  }
  llm -- llm-adapters {
    style.stroke-dash: 2
    style.opacity: 0.6
  }

  brain: brainctl {
    shape: cylinder
    tooltip: "Dual surface: remote MCP (HTTP/SSE) for the LLM provider with READ allowlist В· local stdio MCP for TS-direct writes"
  }
  brain-tools: |md
    **READ allowlist (LLM)**
    `memory_search` В· `entity_get` В· `entity_search`
    `context_search` В· `tom_perspective_get`
    `policy_match` В· `reason` В· `temporal_*`

    **+ consolidator writes**
    `reflexion_write` В· `dream_cycle`
    `consolidation_run` В· `gaps_scan`
    `retirement_analysis`

    **NEVER exposed**
    `memory_add` В· `entity_create` В· `event_add`
    `belief_set` В· `policy_add` В· `trust_*`
  | {
    shape: text
    style.font-size: 11
  }
  brain -- brain-tools {
    style.stroke-dash: 2
    style.opacity: 0.6
  }
}

# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ Strand process в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

strand: strand process {
  style.stroke: "#3b82f6"
  style.stroke-width: 2
  tooltip: "src/orchestrator.ts вЂ” in-process intervals (dev) В· migrate to a queue when prod needs it"

  auth: |md
    ## auth (BYOK)
    `src/auth/`

    **CredentialStore** вЂ” pluggable resolver
    вЂў Env (default В· process.env)
    вЂў File (~/.strand/creds.json, 0600, atomic)
    вЂў EncryptedFile (AES-256-GCM + scrypt KDF)
    вЂў Keychain (@napi-rs/keyring, OS-native)
    вЂў Chained (file+env / encrypted+env / kc+env)
    вЂў TenantScoped (STRAND_TENANT=acme)
    вЂў OAuthStore (decorator)
      В· auto-refresh within 60 s window
      В· atomic rotation via setMany()
      В· per-provider concurrency lock
      В· X strategy preregistered
    `pnpm keys {list,get,set,delete,refresh-oauth}`
  | {
    shape: rectangle
    style.fill: "#1e293b"
    style.stroke: "#10b981"
    style.font-color: "#d1fae5"
  }

  factory: |md
    ## llm() factory
    `src/clients/llm/index.ts`

    async singleton В· switch on `LLM_PROVIDER`
    resolves keys from CredentialStore
    `llm({ credentials: myStore })` for BYOK
    logs capabilities + store name at boot
    tests: `_resetLlmForTests()`
  | {
    shape: rectangle
    style.fill: "#1e293b"
    style.stroke: "#a78bfa"
    style.font-color: "#ede9fe"
  }

  agent_loop: |md
    ## runAgenticLoop
    `src/agent/loop.ts`

    provider-agnostic tool-call iteration
    merges localTools + server tools + MCP
    chat в†’ execute tool locally в†’ re-chat
    cap via maxIterations (default 10)
    dispatches `computer_use` calls
    to `ComputerExecutor` (NoopExecutor default)
    full trace + summed usage returned
  | {
    shape: rectangle
    style.fill: "#1e293b"
    style.stroke: "#38bdf8"
    style.font-color: "#dbeafe"
  }

  executor: |md
    ## ComputerExecutor
    `src/agent/executor.ts`

    **NoopExecutor** (default) вЂ” shadow-mode,
    logs intent, never touches the host

    **DockerExecutor** (implemented) вЂ” real sandbox
    Xvfb + fluxbox + x11vnc + xdotool + scrot
    via `docker exec`. `markSafe()` gate required
    before gated/live use. 16 KB bash cap,
    64 KB stdout truncation, argv-only injection
    (no shell interpolation).

    screenshot В· click В· type В· key В· scroll
    bash В· textEditor В· cursorPosition В· wait
  | {
    shape: rectangle
    style.fill: "#1e293b"
    style.stroke: "#fbbf24"
    style.font-color: "#fef3c7"
  }

  perceiver: |md
    ## Perceiver
    **every 120 s**
    src/loops/perceiver.ts

    вЂў own mentions (sinceId)
    вЂў home timeline
    вЂў DM events
    вЂў NO external scouting
  | {
    shape: rectangle
    style.fill: "#1e3a8a"
    style.stroke: "#3b82f6"
    style.font-color: "#dbeafe"
  }

  reasoner: |md
    ## Reasoner
    **every 300 s В· provider-agnostic**
    src/loops/reasoner.ts

    reads last 50 `perceived_events`
    emits up to 10 `CandidateEnvelope[]`

    `llm().chat({ messages, tools, structuredOutput })`
    `promptCacheKey: strand:reasoner:v1`
    `maxTurns: 5` В· tools from `capabilities.serverSideTools`
    schema: `anyOf` per action.kind

    stuck-mid-thought в†’ retry with
    `previousResponseId` (when supported)
  | {
    shape: rectangle
    style.fill: "#4c1d95"
    style.stroke: "#a78bfa"
    style.font-color: "#ede9fe"
  }

  gate: |md
    ## Policy Gate
    **8 rules В· typestate**

    1 banned_topic
    2 prefilter (regex+topic+embedding)
    3 rate caps (day + hour)
    4 cooldowns (per-target)
    5 relevance в‰Ґ 0.65
    6 dup cos < 0.85 (7d)
    7 diversity (cluster + kind)
    8 dm mutual required
    + human_review

    mints `Candidate<"approved">`
  | {
    shape: hexagon
    style.fill: "#7f1d1d"
    style.stroke: "#ef4444"
    style.stroke-width: 3
    style.font-color: "#fee2e2"
    style.bold: true
  }

  actor: |md
    ## Actor
    **event-driven В· shadow/gated/live**
    src/loops/actor.ts

    accepts only `Candidate<"approved">`

    1. SHA-256 idempotency
    2. dispatch per action.kind
       like В· bookmark В· post В· reply В· quote В· dm
       follow/unfollow (Pro gated)
    3. rate counters++ В· cooldowns
    4. `brain.outcome_annotate`
  | {
    shape: rectangle
    style.fill: "#78350f"
    style.stroke: "#f59e0b"
    style.font-color: "#fef3c7"
  }

  consolidator: |md
    ## Consolidator
    **submit 24 h В· poll 30 min**
    _poll not yet wired_

    5 task JSONL via llm.filesUpload в†’ batchCreate
    _if `capabilities.batch` вЂ” else sync fallback_

    tasks: dream_cycle В· consolidation_run
    gaps_scan В· retirement_analysis
    reflexion_write
  | {
    shape: rectangle
    style.fill: "#083344"
    style.stroke: "#06b6d4"
    style.font-color: "#cffafe"
  }

  sqlite: |md
    ## SQLite ops store
    src/db/schema.sql

    `action_log` idempotency_key UK
    `cooldowns` В· `rate_counters`
    `reasoner_runs` В· `consolidator_runs`
    `post_embeddings` (7d dup window)
    `perceived_events` В· `dlq`
    `human_review_queue`

    _brain.db owns the semantic layer вЂ”_
    _strand.db is audit + ops only_
  | {
    shape: cylinder
    style.fill: "#042f2e"
    style.stroke: "#14b8a6"
    style.font-color: "#ccfbf1"
  }

  # intra edges
  auth -> factory: "credentials()" { style.stroke: "#10b981"; style.stroke-width: 2 }
  factory -> reasoner: "await llm()" { style.stroke: "#a78bfa" }
  factory -> consolidator: "await llm() + hasBatch()" { style.stroke: "#a78bfa" }
  factory -> agent_loop: "provider.chat()" { style.stroke: "#a78bfa"; style.stroke-dash: 3 }
  agent_loop -> executor: "dispatch computer_use" { style.stroke: "#fbbf24" }
  reasoner -> agent_loop: "(opt-in for\\nfunction-tool loops)" { style.stroke: "#64748b"; style.stroke-dash: 4 }
  perceiver -> sqlite: "INSERT perceived_events"
  sqlite -> reasoner: "SELECT last 50 events" { style.stroke-dash: 3 }
  reasoner -> gate: "CandidateEnvelope[]" { style.stroke: "#a78bfa"; style.stroke-width: 2 }
  gate -> actor: "Candidate<approved>" { style.stroke: "#10b981"; style.stroke-width: 3; style.bold: true }
  gate -> sqlite: "rejected в†’ action_log + reasons[]" { style.stroke: "#f87171"; style.stroke-dash: 3 }
  actor -> sqlite: "action_log + rate_counters"
  reasoner -> sqlite: "reasoner_runs"
  consolidator -> sqlite: "consolidator_runs"
}

# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ External в†” Strand в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

external.x -> strand.perceiver: "poll" { style.stroke: "#38bdf8"; style.stroke-width: 2 }
strand.actor -> external.x: "writes" { style.stroke: "#38bdf8"; style.stroke-width: 3; style.bold: true }
external.llm -> strand.factory: "provider.chat()" { style.stroke: "#c084fc"; style.stroke-width: 2 }
external.llm -> strand.factory: "provider.batch*()" { style.stroke: "#c084fc"; style.stroke-dash: 4 }
external.brain -> strand.reasoner: "MCP read" { style.stroke: "#10b981"; style.stroke-width: 2 }
external.brain -> strand.consolidator: "MCP read + consolidation" { style.stroke: "#10b981"; style.stroke-dash: 4 }
strand.perceiver -> external.brain: "event_add" { style.stroke: "#10b981"; style.stroke-dash: 2 }
strand.actor -> external.brain: "outcome_annotate" { style.stroke: "#10b981"; style.stroke-dash: 2 }
external.x -> strand.auth: "OAuth2 PKCE refresh" { style.stroke: "#38bdf8"; style.stroke-dash: 4 }

# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ Phase status в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

status: Phase status {
  near: bottom-center
  grid-columns: 3
  grid-gap: 24

  wired: |md
    ### вњ“ wired on main
    вЂў typestate gate В· reasoner via runAgenticLoop
    вЂў 4 adapters: openai-compat В· anthropic В· xai В· gemini
    вЂў `llm()` factory + capabilities-driven features
    вЂў **BYOK credential stores**: env В· file В· encrypted-file
       (AES-256-GCM + scrypt) В· keychain (@napi-rs/keyring) В·
       chained В· **tenant-scoped** (STRAND_TENANT)
    вЂў **OAuthCredentialStore** decorator вЂ” atomic refresh
       + concurrency lock; X strategy preregistered
    вЂў `pnpm keys` CLI (list/get/set/delete/refresh-oauth)
    вЂў `runAgenticLoop` вЂ” local tool-call iteration runner
    вЂў computer-use tool type + Anthropic native mapping
    вЂў `NoopExecutor` + real `DockerExecutor`
    вЂў consolidator: file batch В· inline batch В· sync fallback
    вЂў consolidatorPoll wired (30 min)
    вЂў multi-turn message history native on xAI
    вЂў 194 tests В· smoke 376 ms В· typecheck+biome clean
  | {
    shape: rectangle
    style.fill: "#064e3b"
    style.stroke: "#10b981"
    style.font-color: "#d1fae5"
  }

  next: |md
    ### вџі next
    вЂў X v2 live writes on real creds (phase 3)
    вЂў OAuth setup + bootstrap-memory runs
    вЂў grokCompose opt-in (two-stage composer)
    вЂў Docker image `strand-sandbox:latest` build
    вЂў label 100 candidates В· в‰Ґ 80% shadow agreement
    вЂў phase 7: Pro tier в†’ follow variant live
    вЂў Gemini Batch API (Vertex path)
  | {
    shape: rectangle
    style.fill: "#451a03"
    style.stroke: "#f59e0b"
    style.font-color: "#fde68a"
  }

  never: |md
    ### вњ• never
    вЂў DMs to non-mutuals
    вЂў action bypassing the policy gate
    вЂў brainctl mutations via remote MCP
    вЂў prompts as inline strings
    вЂў provider-specific leakage outside `src/clients/llm/`
    вЂў follow variant on Basic tier
  | {
    shape: rectangle
    style.fill: "#450a0a"
    style.stroke: "#ef4444"
    style.font-color: "#fecaca"
  }
}
