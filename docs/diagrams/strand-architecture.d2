  style.stroke: "#c084fc"
  style.stroke-width: 2
}
external.xai -> strand.consolidator: "Batch API" {
  style.stroke: "#c084fc"
  style.stroke-dash: 4
}
external.brain -> strand.reasoner: "MCP read" {
  style.stroke: "#10b981"
  style.stroke-width: 2
}
external.brain -> strand.consolidator: "MCP read + consolidation" {
  style.stroke: "#10b981"
  style.stroke-dash: 4
}
strand.perceiver -> external.brain: "event_add" {
  style.stroke: "#10b981"
  style.stroke-dash: 2
}
strand.actor -> external.brain: "outcome_annotate" {
  style.stroke: "#10b981"
  style.stroke-dash: 2
}

# ═════════════════════ Phase status ═════════════════════

status: Phase status {
  near: bottom-center
  grid-columns: 3
  grid-gap: 24

  wired: |md
    ### ✓ wired on main
    • typestate gate
    • reasoner schema + cache key + chaining
    • consolidator Batch submit + poll helpers
    • brainctl r/w surface
    • prefilter (regex + topic + embedding)
    • `grokCompose` library
    • `replay-shadow` regression tool
    • 84 tests green · smoke 254 ms
  | {
    shape: rectangle
    style.fill: "#064e3b"
    style.stroke: "#10b981"
    style.font-color: "#d1fae5"
  }

  next: |md
    ### ⟳ next
    • wire `consolidatorPoll` into orchestrator
    • phase 3: 48 h perceiver on real X creds
    • label 100 candidates
    • ≥ 80% shadow agreement
    • phase 4+: composer opt-in (two-stage)
    • phase 7: Pro tier → follow variant live
  | {
    shape: rectangle
    style.fill: "#451a03"
    style.stroke: "#f59e0b"
    style.font-color: "#fde68a"
  }

  never: |md
    ### ✕ never
    • DMs to non-mutuals
    • action bypassing the policy gate
    • brainctl mutations via Grok MCP
    • prompts as inline strings
    • Deferred Completions for Consolidator
    • follow variant on Basic tier
  | {
    shape: rectangle
    style.fill: "#450a0a"
    style.stroke: "#ef4444"
    style.font-color: "#fecaca"
  }
}
