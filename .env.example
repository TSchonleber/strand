# ─── xAI / Grok ───────────────────────────────────────────────
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
GROK_MODEL_REASONER=grok-4.20-reasoning
GROK_MODEL_COMPOSER=grok-4-1-fast-non-reasoning
GROK_MODEL_JUDGE=grok-4-1-fast-non-reasoning
# Dated alias format for prod determinism: <base>-<MMDD>-<flavor> (NOT YYYY-MM-DD)
# GROK_MODEL_REASONER=grok-4.20-0309-reasoning

# ─── X API v2 ─────────────────────────────────────────────────
# App-level (for bearer token auth on read endpoints we own)
X_CLIENT_ID=
X_CLIENT_SECRET=
X_BEARER_TOKEN=

# User OAuth 2.0 PKCE — populated by `pnpm oauth:setup`
X_USER_ID=
X_USER_ACCESS_TOKEN=
X_USER_REFRESH_TOKEN=
X_USER_TOKEN_EXPIRES_AT=

# OAuth redirect (use http://localhost:4567/callback for local setup)
X_OAUTH_REDIRECT_URI=http://localhost:4567/callback

# ─── brainctl ─────────────────────────────────────────────────
# Local path (for TS-direct writes from Perceiver/Actor).
BRAINCTL_COMMAND=brainctl
BRAINCTL_ARGS=mcp
BRAINCTL_AGENT_ID=strand

# Remote MCP endpoint exposed to Grok — MUST be Streaming HTTP or SSE (stdio is rejected by xAI).
BRAINCTL_REMOTE_MCP_URL=
BRAINCTL_REMOTE_MCP_TOKEN=

# ─── Runtime ──────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# In-process scheduler in dev; Redis in prod
REDIS_URL=

# SQLite path
DATABASE_PATH=./data/strand.db

# ─── Operational mode ─────────────────────────────────────────
# shadow  → reasoner proposes, actor disabled
# gated   → actor enabled, human review required per policy
# live    → fully autonomous within policy caps
STRAND_MODE=shadow

# Human review sink
REVIEW_SINK=stdout
# Options: stdout | slack
SLACK_WEBHOOK_URL=

# ─── X API tier gate ──────────────────────────────────────────
# basic = $200/mo, 10k posts/mo, NO follow endpoints
# pro   = $5000/mo, 1M posts/mo, follows available
# Follow action variant compiles out when TIER=basic.
TIER=basic
