# ─── Credential store (BYOK) ───────────────────────────────────
# env                    → reads from this file (default)
# file                   → ~/.strand/credentials.json, 0600
# file+env               → file wins, env fallback
# encrypted-file         → AES-256-GCM + scrypt (needs STRAND_CREDENTIAL_PASSPHRASE)
# encrypted-file+env     → encrypted file, env fallback
# keychain               → OS keyring via @napi-rs/keyring (install separately)
# keychain+env           → keyring, env fallback
STRAND_CREDENTIAL_STORE=env

# Required when STRAND_CREDENTIAL_STORE is `encrypted-file` or `encrypted-file+env`.
# At least 8 chars. Keep this passphrase out of the encrypted file itself.
STRAND_CREDENTIAL_PASSPHRASE=

# Multi-tenant: when set, every credential key is namespaced tenant:<id>:<key>.
# Ship this env per-process for each tenant in a shared Strand deployment.
STRAND_TENANT=

# ─── LLM provider (agnostic) ───────────────────────────────────
# Pick one: xai | openai | anthropic | gemini
LLM_PROVIDER=xai

# Model names are passed verbatim to the selected provider. Defaults work
# for xAI; override per provider:
#   xai       → grok-4.20-reasoning          · grok-4-1-fast-non-reasoning
#   openai    → gpt-5                        · gpt-5-mini
#   anthropic → claude-opus-4-7              · claude-haiku-4-5
#   gemini    → gemini-2.5-pro               · gemini-2.5-flash
LLM_MODEL_REASONER=grok-4.20-reasoning
LLM_MODEL_COMPOSER=grok-4-1-fast-non-reasoning
LLM_MODEL_JUDGE=grok-4-1-fast-non-reasoning

# ─── Per-provider credentials (set only the ones you use) ─────
# xAI — dated prod alias format: <base>-<MMDD>-<flavor> (NOT YYYY-MM-DD)
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1

# OpenAI + OpenAI-compatible endpoints (Ollama, Groq, Together, LM Studio, vLLM)
# Set OPENAI_BASE_URL to override: e.g. http://localhost:11434/v1 for Ollama
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# Google Gemini (@google/genai SDK)
GEMINI_API_KEY=

# ─── X API v2 ─────────────────────────────────────────────────
# App-level (for bearer token auth on read endpoints we own)
X_CLIENT_ID=
X_CLIENT_SECRET=
X_BEARER_TOKEN=

# User OAuth 2.0 PKCE — populated by `pnpm oauth:setup`
X_USER_ID=
X_USER_ACCESS_TOKEN=
X_USER_REFRESH_TOKEN=
X_USER_TOKEN_EXPIRES_AT=

# OAuth redirect (use http://localhost:4567/callback for local setup)
X_OAUTH_REDIRECT_URI=http://localhost:4567/callback

# ─── brainctl ─────────────────────────────────────────────────
# Local path (for TS-direct writes from Perceiver/Actor).
BRAINCTL_COMMAND=brainctl
BRAINCTL_ARGS=mcp
BRAINCTL_AGENT_ID=strand

# Remote MCP endpoint exposed to the LLM provider.
# xAI + Anthropic + OpenAI Responses require HTTP/SSE (stdio rejected).
# Gemini has no MCP support (adapter drops mcp tools with a warn).
BRAINCTL_REMOTE_MCP_URL=
BRAINCTL_REMOTE_MCP_TOKEN=

# ─── Runtime ──────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# SQLite path
DATABASE_PATH=./data/strand.db

# ─── Operational mode ─────────────────────────────────────────
# shadow  → reasoner proposes, actor disabled
# gated   → actor enabled, human review required per policy
# live    → fully autonomous within policy caps
STRAND_MODE=shadow

# Human review sink
REVIEW_SINK=stdout
SLACK_WEBHOOK_URL=

# ─── X API tier gate ──────────────────────────────────────────
# basic = 200 USD/mo, 10k posts/mo, NO follow endpoints
# pro   = 5000 USD/mo, 1M posts/mo, follows available
TIER=basic
